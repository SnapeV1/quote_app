<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D12"
    android:padding="16dp">

    <TextView
        android:id="@+id/widget_quote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#E0E0E0"
        android:textSize="13sp"
        android:fontFamily="serif"
        android:textStyle="italic"
        android:layout_above="@+id/widget_author"
        android:layout_alignParentTop="true"
        android:maxLines="5"
        android:ellipsize="end"
        android:text="Open DailyLine to load your quote"/>

    <TextView
        android:id="@+id/widget_author"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:textColor="#D4AF6A"
        android:textSize="11sp"
        android:textStyle="bold"
        android:text=""/>

    <TextView
        android:id="@+id/widget_book"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_toEndOf="@+id/widget_author"
        android:textColor="#888888"
        android:textSize="10sp"
        android:text=""/>

</RelativeLayout>